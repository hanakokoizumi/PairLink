# Optional — zero-config works without this file.
# Copy only when you need to override defaults: cp .env.example .env

PORT=8080
PUBLIC_URL=http://localhost:8080
LOG_LEVEL=info
PAIRLINK_LOAD_DOTENV=true

DISABLE_AUTH=
JWT_SECRET=
JWT_EXPIRE=24h

PAIRLINK_USERS=

OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/api/auth/oidc/callback
# When using `make dev` (Next.js on :3000), set:
# OIDC_REDIRECT_URL=http://localhost:3000/api/auth/oidc/callback
OIDC_ALLOW_EMAIL_DOMAINS=
OIDC_ALLOW_EMAILS=
OIDC_ALLOW_GROUPS=
OIDC_GROUPS_CLAIM=groups
OIDC_REQUIRE_EMAIL_VERIFIED=false

RTC_CONFIG={"iceServers":[{"urls":"stun:stun.l.google.com:19302"}]}
WS_FALLBACK=true
ICE_TIMEOUT_SEC=15

ROOM_CODE_TTL=30m
ROOM_CODE_LENGTH=5
JOIN_RATE_LIMIT=10
RATE_LIMIT_PER_IP=100

AUTO_ACCEPT_FILES=true
DEFAULT_MASK_ON_SEND=false
DEFAULT_THEME=dark
DEFAULT_LOCALE=zh-CN
SUPPORTED_LOCALES=zh-CN,en,zh-TW,ja,ko

FILE_MAX_SIZE_BYTES=5368709120
MESSAGE_MAX_LENGTH=65536
RESUME_TRANSFER_ENABLED=true

SECURITY_HEADERS=true
LOGIN_RATE_LIMIT=10
WS_MAX_MESSAGE_BYTES=1048576

NEXT_PUBLIC_API_URL=

# Next.js dev: extra origins for LAN access (comma-separated hostnames/IPs)
ALLOWED_DEV_ORIGINS=

# Docker image internal ports (used by deploy/docker-entrypoint.sh; INTERNAL_API_URL is baked at image build)
PAIRLINK_API_PORT=8081
PAIRLINK_WEB_PORT=8080
INTERNAL_API_URL=http://127.0.0.1:8081

# Docker image (optional overrides for docker compose pull)
GHCR_OWNER=hanakokoizumi
PAIRLINK_TAG=latest
