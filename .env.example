# Optional — zero-config works without this file.
# Copy only when you need to override defaults: cp .env.example .env

PORT=8080
PUBLIC_URL=http://localhost:8080
LOG_LEVEL=info
PAIRLINK_LOAD_DOTENV=true

DISABLE_AUTH=
JWT_SECRET=
JWT_EXPIRE=24h

PAIRLINK_USERS=

OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/api/auth/oidc/callback
# When using `make dev` (Next.js on :3000), set:
# OIDC_REDIRECT_URL=http://localhost:3000/api/auth/oidc/callback
OIDC_ALLOW_EMAIL_DOMAINS=
OIDC_ALLOW_EMAILS=
OIDC_ALLOW_GROUPS=
OIDC_GROUPS_CLAIM=groups
OIDC_REQUIRE_EMAIL_VERIFIED=false

# TURN relay (auto at Docker start; no turnserver.conf). coturn generates TURN_PASSWORD if unset.
TURN_ENABLED=true
TURN_HOST=
TURN_PORT=3478
TURN_REALM=pairlink
TURN_USER=pairlink
TURN_PASSWORD=
# Set on servers behind NAT when auto-detection is not enough:
TURN_EXTERNAL_IP=

# STUN servers (comma-separated host:port or stun: URL). Merged into RTC_CONFIG; manual TURN stays in RTC_CONFIG.
# Defaults include Google STUN plus China-accessible stun.miwifi.com and stun.qq.com.
STUN_SERVERS=stun.l.google.com:19302,stun1.l.google.com:19302,stun.miwifi.com:3478,stun.qq.com:3478
# TURN and other non-STUN ICE servers (JSON). STUN entries here are replaced by STUN_SERVERS.
RTC_CONFIG={"iceServers":[]}
WS_FALLBACK=true
ICE_TIMEOUT_SEC=15

ROOM_CODE_TTL=30m
ROOM_CODE_LENGTH=5
# WS host-join / join-room attempts per IP per minute (0 = disable WS join limit)
JOIN_RATE_LIMIT=10
# HTTP GET /api/rooms/lookup per IP per minute
LOOKUP_RATE_LIMIT=30
# WebSocket upgrade (GET /ws) per IP per minute
WS_CONNECT_RATE_LIMIT=30
RATE_LIMIT_PER_IP=100
# Comma-separated CIDRs for reverse proxies that may set X-Forwarded-For
TRUSTED_PROXY_CIDRS=

AUTO_ACCEPT_FILES=true
DEFAULT_MASK_ON_SEND=false
DEFAULT_THEME=system
DEFAULT_LOCALE=zh-CN
SUPPORTED_LOCALES=zh-CN,en,zh-TW,ja,ko

FILE_MAX_SIZE_BYTES=5368709120
MESSAGE_MAX_LENGTH=65536
RESUME_TRANSFER_ENABLED=true

SECURITY_HEADERS=true
LOGIN_RATE_LIMIT=10
WS_MAX_MESSAGE_BYTES=1048576

NEXT_PUBLIC_API_URL=

# Next.js dev: extra origins for LAN access (comma-separated hostnames/IPs)
ALLOWED_DEV_ORIGINS=

# Docker image internal ports (used by deploy/docker-entrypoint.sh; INTERNAL_API_URL is baked at image build)
PAIRLINK_API_PORT=8081
PAIRLINK_WEB_PORT=8080
INTERNAL_API_URL=http://127.0.0.1:8081

# Docker image (optional overrides for docker compose pull)
GHCR_OWNER=hanakokoizumi
PAIRLINK_TAG=latest
